#!/bin/sh
. "${HOME}/.local/bin/sb-lib.sh" || exit 1

CLI="token-usage"

sb_on_left_click() {
    body=$("$CLI" --detail 2>/dev/null) || {
        sb_notify "AI Usage" "failed to fetch"
        return
    }
    sb_notify "AI Usage" "$body"
}

sb_on_middle_click() {
    if command -v claude-monitor >/dev/null 2>&1; then
        sb_terminal claude-monitor
    else
        sb_notify "AI Usage" "claude-monitor not installed"
    fi
}

sb_on_right_click() {
    sb_module_help "🤖" "AI Usage" "Left: details · Middle: claude-monitor · Right: help"
}

sb_handle_buttons

"$CLI" --statusbar 2>/dev/null || printf "🤖 err"
